# ─────────────────────────────────────────────────────────────
#  Cœur d'Adorateur — Variables d'environnement
#  Copie ce fichier en `.env.local` et remplis les valeurs.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...            # clé "anon public"
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...                # clé "service_role" (SECRET, serveur uniquement)

# Brevo (https://app.brevo.com → SMTP & API → API Keys)
BREVO_API_KEY=xkeysib-...
# Expéditeur des emails (doit être un expéditeur vérifié dans Brevo)
BREVO_SENDER_EMAIL=notifications@ton-domaine.com
BREVO_SENDER_NAME=Cœur d'Adorateur

# Emails des administrateurs qui reçoivent les notifications d'inscription
# (séparés par des virgules)
ADMIN_EMAILS=admin1@exemple.com,admin2@exemple.com

# URL publique de l'application (sans slash final)
NEXT_PUBLIC_APP_URL=https://coeur-dadorateur.vercel.app

# Secret protégeant la route de cron /api/cron/ping
# Génère une valeur aléatoire : openssl rand -hex 32
CRON_SECRET=change-moi-avec-une-valeur-aleatoire-longue
